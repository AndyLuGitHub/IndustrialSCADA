<UserControl x:Class="IndustrialSCADA.Module.Dashboard.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ════════════════════════════════════════════════════════════
                 TOP ROW: Statistics overview cards
                 ════════════════════════════════════════════════════════════ -->
            <UniformGrid Grid.Row="0" Columns="4">

                <!-- Total Devices -->
                <materialDesign:Card Margin="4" Padding="16">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <materialDesign:PackIcon Kind="Devices" Width="28" Height="28"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                     VerticalAlignment="Center" />
                            <TextBlock DockPanel.Dock="Right" Text="Devices"
                                       FontSize="13" Opacity="0.6" VerticalAlignment="Center"
                                       Margin="8,0,0,0" />
                        </DockPanel>
                        <TextBlock Text="{Binding TotalDeviceCount}"
                                   FontSize="36" FontWeight="Bold" Margin="0,4,0,0" />
                    </StackPanel>
                </materialDesign:Card>

                <!-- Online Devices -->
                <materialDesign:Card Margin="4" Padding="16">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <materialDesign:PackIcon Kind="ServerNetwork" Width="28" Height="28"
                                                     Foreground="{DynamicResource SecondaryHueMidBrush}"
                                                     VerticalAlignment="Center" />
                            <TextBlock DockPanel.Dock="Right" Text="Online"
                                       FontSize="13" Opacity="0.6" VerticalAlignment="Center"
                                       Margin="8,0,0,0" />
                        </DockPanel>
                        <TextBlock Text="{Binding OnlineDeviceCount}"
                                   FontSize="36" FontWeight="Bold" Margin="0,4,0,0"
                                   Foreground="{DynamicResource SecondaryHueMidBrush}" />
                    </StackPanel>
                </materialDesign:Card>

                <!-- Unhandled Alarms -->
                <materialDesign:Card Margin="4" Padding="16">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <materialDesign:PackIcon Kind="AlertCircle" Width="28" Height="28"
                                                     Foreground="{DynamicResource ValidationErrorBrush}"
                                                     VerticalAlignment="Center" />
                            <TextBlock DockPanel.Dock="Right" Text="Alarms"
                                       FontSize="13" Opacity="0.6" VerticalAlignment="Center"
                                       Margin="8,0,0,0" />
                        </DockPanel>
                        <TextBlock Text="{Binding UnhandledAlarmCount}"
                                   FontSize="36" FontWeight="Bold" Margin="0,4,0,0"
                                   Foreground="{DynamicResource ValidationErrorBrush}" />
                    </StackPanel>
                </materialDesign:Card>

                <!-- Today's Count (Counter) -->
                <materialDesign:Card Margin="4" Padding="16">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <materialDesign:PackIcon Kind="Counter" Width="28" Height="28"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                     VerticalAlignment="Center" />
                            <TextBlock DockPanel.Dock="Right" Text="Production"
                                       FontSize="13" Opacity="0.6" VerticalAlignment="Center"
                                       Margin="8,0,0,0" />
                        </DockPanel>
                        <TextBlock Text="{Binding Counter}"
                                   FontSize="36" FontWeight="Bold" Margin="0,4,0,0" />
                    </StackPanel>
                </materialDesign:Card>
            </UniformGrid>

            <!-- ════════════════════════════════════════════════════════════
                 MIDDLE ROW: Real-time data cards
                 ════════════════════════════════════════════════════════════ -->
            <UniformGrid Grid.Row="2" Columns="4">

                <!-- Temperature Card -->
                <materialDesign:Card Margin="4" Padding="16">
                    <StackPanel>
                        <DockPanel>
                            <materialDesign:PackIcon Kind="Thermometer" Width="24" Height="24"
                                                     Foreground="OrangeRed"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Temperature" FontSize="14" FontWeight="Medium"
                                       Margin="8,0,0,0" VerticalAlignment="Center" />
                            <!-- Quality indicator -->
                            <Ellipse Width="10" Height="10" HorizontalAlignment="Right"
                                     VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="Gray" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TemperatureQualityGood}"
                                                         Value="True">
                                                <Setter Property="Fill" Value="LimeGreen" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </DockPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="{Binding Temperature, StringFormat=F1}"
                                       FontSize="36" FontWeight="Bold" />
                            <TextBlock Text=" &#x00b0;C" FontSize="18" Opacity="0.6"
                                       VerticalAlignment="Bottom" Margin="2,0,0,6" />
                        </StackPanel>
                        <TextBlock Opacity="0.5" FontSize="11" Margin="0,4,0,0">
                            <Run Text="High Limit: " />
                            <Run Text="{Binding TemperatureHighLimit, StringFormat=F0, Mode=OneWay}" />
                            <Run Text=" &#x00b0;C" />
                        </TextBlock>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Pressure Card -->
                <materialDesign:Card Margin="4" Padding="16">
                    <StackPanel>
                        <DockPanel>
                            <materialDesign:PackIcon Kind="Gauge" Width="24" Height="24"
                                                     Foreground="DodgerBlue"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Pressure" FontSize="14" FontWeight="Medium"
                                       Margin="8,0,0,0" VerticalAlignment="Center" />
                        </DockPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="{Binding Pressure, StringFormat=F2}"
                                       FontSize="36" FontWeight="Bold" />
                            <TextBlock Text=" bar" FontSize="18" Opacity="0.6"
                                       VerticalAlignment="Bottom" Margin="2,0,0,6" />
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Motor State Card -->
                <materialDesign:Card Margin="4" Padding="16">
                    <StackPanel>
                        <DockPanel>
                            <materialDesign:PackIcon Kind="Engine" Width="24" Height="24"
                                                     VerticalAlignment="Center">
                                <materialDesign:PackIcon.Style>
                                    <Style TargetType="materialDesign:PackIcon">
                                        <Setter Property="Foreground" Value="Gray" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MotorState}" Value="True">
                                                <Setter Property="Foreground"
                                                        Value="{DynamicResource SecondaryHueMidBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </materialDesign:PackIcon.Style>
                            </materialDesign:PackIcon>
                            <TextBlock Text="Motor State" FontSize="14" FontWeight="Medium"
                                       Margin="8,0,0,0" VerticalAlignment="Center" />
                        </DockPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <materialDesign:PackIcon Width="40" Height="40"
                                                     VerticalAlignment="Center">
                                <materialDesign:PackIcon.Style>
                                    <Style TargetType="materialDesign:PackIcon">
                                        <Setter Property="Kind" Value="Stop" />
                                        <Setter Property="Foreground" Value="Gray" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MotorState}" Value="True">
                                                <Setter Property="Kind" Value="Play" />
                                                <Setter Property="Foreground"
                                                        Value="{DynamicResource SecondaryHueMidBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </materialDesign:PackIcon.Style>
                            </materialDesign:PackIcon>
                            <TextBlock FontSize="24" FontWeight="Bold"
                                       VerticalAlignment="Center" Margin="8,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="STOPPED" />
                                        <Setter Property="Foreground" Value="Gray" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MotorState}" Value="True">
                                                <Setter Property="Text" Value="RUNNING" />
                                                <Setter Property="Foreground"
                                                        Value="{DynamicResource SecondaryHueMidBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Counter Card -->
                <materialDesign:Card Margin="4" Padding="16">
                    <StackPanel>
                        <DockPanel>
                            <materialDesign:PackIcon Kind="Counter" Width="24" Height="24"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Counter" FontSize="14" FontWeight="Medium"
                                       Margin="8,0,0,0" VerticalAlignment="Center" />
                        </DockPanel>
                        <TextBlock Text="{Binding Counter}"
                                   FontSize="36" FontWeight="Bold" Margin="0,8,0,0" />
                    </StackPanel>
                </materialDesign:Card>
            </UniformGrid>

            <!-- ════════════════════════════════════════════════════════════
                 BOTTOM: LiveCharts2 trend chart
                 ════════════════════════════════════════════════════════════ -->
            <materialDesign:Card Grid.Row="4" Padding="16" Margin="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Temperature &amp; Pressure Trend (Last 60s)"
                               FontSize="16" FontWeight="Medium" Margin="0,0,0,8" />
                    <lvc:CartesianChart Grid.Row="1"
                                        Series="{Binding Series}"
                                        XAxes="{Binding XAxes}"
                                        YAxes="{Binding YAxes}"
                                        MinHeight="280" />
                </Grid>
            </materialDesign:Card>
        </Grid>
    </ScrollViewer>
</UserControl>
