<Window x:Class="IndustrialSCADA.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{Binding Title}"
        Width="1400"
        Height="900"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MaterialDesignWindow}">

    <materialDesign:DialogHost Identifier="RootDialog">
        <DockPanel LastChildFill="True">

            <!-- Top: ToolBar -->
            <materialDesign:ColorZone DockPanel.Dock="Top"
                                      Mode="PrimaryMid"
                                      Padding="8">
                <DockPanel>
                    <TextBlock Text="Industrial SCADA"
                               FontSize="20"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="16,0,0,0" />
                    <Button DockPanel.Dock="Right"
                            HorizontalAlignment="Right"
                            Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="Toggle Theme"
                            Command="{Binding ToggleThemeCommand}">
                        <materialDesign:PackIcon Kind="Brightness6" />
                    </Button>
                </DockPanel>
            </materialDesign:ColorZone>

            <!-- Bottom: StatusBar -->
            <StatusBar DockPanel.Dock="Bottom"
                       Background="{DynamicResource MaterialDesignPaper}"
                       Foreground="{DynamicResource MaterialDesignBody}">
                <StatusBarItem>
                    <TextBlock>
                        <Run Text="Time: " />
                        <Run Text="{Binding CurrentTime, Mode=OneWay}" />
                    </TextBlock>
                </StatusBarItem>
                <Separator />
                <StatusBarItem>
                    <TextBlock>
                        <Run Text="Online Devices: " />
                        <Run Text="{Binding OnlineDeviceCount, Mode=OneWay}" />
                    </TextBlock>
                </StatusBarItem>
                <Separator />
                <StatusBarItem>
                    <TextBlock>
                        <Run Text="Unhandled Alarms: " />
                        <Run Text="{Binding UnhandledAlarmCount, Mode=OneWay}" />
                    </TextBlock>
                </StatusBarItem>
            </StatusBar>

            <!-- Left: Navigation TreeView -->
            <Border DockPanel.Dock="Left"
                    Width="220"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="0,0,1,0"
                    Background="{DynamicResource MaterialDesignCardBackground}">
                <TreeView x:Name="NavigationTree"
                          SelectedItemChanged="NavigationTree_SelectedItemChanged"
                          Margin="0,8">
                    <TreeViewItem Tag="DashboardView">
                        <TreeViewItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ViewDashboard" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="Dashboard" />
                            </StackPanel>
                        </TreeViewItem.Header>
                    </TreeViewItem>
                    <TreeViewItem Tag="DeviceControlView">
                        <TreeViewItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Devices" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="Device Control" />
                            </StackPanel>
                        </TreeViewItem.Header>
                    </TreeViewItem>
                    <TreeViewItem Tag="DataAcquisitionView">
                        <TreeViewItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="DatabaseSync" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="Data Acquisition" />
                            </StackPanel>
                        </TreeViewItem.Header>
                    </TreeViewItem>
                    <TreeViewItem Tag="AlarmManagementView">
                        <TreeViewItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AlarmBell" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="Alarm Management" />
                            </StackPanel>
                        </TreeViewItem.Header>
                    </TreeViewItem>
                    <TreeViewItem Tag="LogViewerView">
                        <TreeViewItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileDocumentOutline" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="Log Viewer" />
                            </StackPanel>
                        </TreeViewItem.Header>
                    </TreeViewItem>
                </TreeView>
            </Border>

            <!-- Center: 主内容区，使用 Prism Region 导航 -->
            <ContentControl prism:RegionManager.RegionName="MainRegion"
                            Margin="0" />
        </DockPanel>
    </materialDesign:DialogHost>
</Window>
